# Модель Whisper: tiny / base / small / medium / large-v3
WHISPER_MODEL=small

# Тип вычислений CTranslate2: int8 (быстро) / int8_float16 / float32
WHISPER_COMPUTE_TYPE=int8

# Язык: ru или auto для автоопределения
WHISPER_LANGUAGE=ru

# Куда качать модель (по умолчанию кеш HuggingFace)
# WHISPER_DOWNLOAD_ROOT=

# Токен Hugging Face — убирает троттлинг анонимных загрузок (быстрее качает
# модели). Получить: https://huggingface.co/settings/tokens (read-доступа хватит).
# HF_TOKEN=

# Gradio
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7861
